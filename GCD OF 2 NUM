#include <iostream>
using namespace std;

void GCDOfTwoNumbers() {
    int num1, num2;
    cout << "Enter two num: ";
    cin >> num1 >> num2;

  if (num1 > num2) {
        swap(num1, num2);
    }

  int gcd = 1; 
    for (int i = 1; i <= num1; ++i) {
        if (num1 % i == 0 && num2 % i == 0) {
            gcd = i; 
        }
    }

   cout << "GCD of " << num1 << " AND " << num2 << " is: " << gcd << endl;
}




int main() {
    GCDOfTwoNumbers();
return 0;
}
